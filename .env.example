# ETF FOF — 环境变量配置
# 复制本文件为 .env 并填入你的密钥:  cp .env.example .env

# ============================================================
# Tushare (必需 — ETF/指数/行情/成分权重数据源)
# 注册: https://tushare.pro/register
# ============================================================
TUSHARE_TOKEN=

# ============================================================
# LLM 报告解释 (可选 — 不配置则跳过叙述性解释)
#
# 只需设置 LLM_PROVIDER 和 LLM_API_KEY 即可，模型和接口地址会自动填充。
# 也可通过 LLM_MODEL / LLM_API_BASE 覆盖默认值。
# LLM 只用于报告解释和风险提示，不参与打分、权重或回测计算。
# ============================================================

# provider: openai / claude / minimax / kimi / custom
LLM_PROVIDER=minimax
LLM_API_KEY=

# (可选) provider 专属 key；未设置 LLM_API_KEY 时使用
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MINIMAX_API_KEY=
# MOONSHOT_API_KEY=

# (可选) 覆盖默认模型
# LLM_MODEL=
#
# 各 provider 默认模型:
#   openai  -> gpt-4o-mini
#   claude  -> claude-sonnet-4-6
#   minimax -> MiniMax-M2.5
#   kimi    -> kimi-k2.5

# (可选) 覆盖默认接口地址
# LLM_API_BASE=
#
# 各 provider 默认接口:
#   openai  -> https://api.openai.com/v1
#   claude  -> https://api.anthropic.com
#   minimax -> https://api.minimaxi.com/anthropic
#   kimi    -> https://api.kimi.com/coding

# ============================================================
# 注册链接
#   OpenAI:  https://platform.openai.com/
#   Claude:  https://console.anthropic.com/
#   MiniMax: https://platform.minimaxi.com/
#   Kimi:    https://platform.moonshot.cn/
# ============================================================
