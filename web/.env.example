# NextAuth.js / Auth.js v5 — Google OAuth gating for the dashboard.
# Copy this file to web/.env.local and fill in real values.

# Random 32+ byte secret used to sign session JWTs.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client credentials (Google Cloud Console → Credentials → OAuth 2.0 Client ID).
# Authorized redirect URI for local dev:
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma- or space-separated list of Google account emails allowed to sign in.
# An empty list fails closed: nobody can log in until at least one entry is set.
ALLOWED_USERS=

# Backend dashboard API base URL. Change if you serve uvicorn elsewhere.
FOF_API_BASE=http://127.0.0.1:8000
